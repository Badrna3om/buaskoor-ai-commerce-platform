{
  "name": "WooCommerce Order Creation - Public",
  "nodes": [
    {
      "parameters": {
        "inputSource": "passthrough"
      },
      "typeVersion": 1.1,
      "name": "When Executed by Another Workflow",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "position": [
        272,
        352
      ]
    },
    {
      "parameters": {
        "jsCode": "// =====================================\n// PRODUCT IDS\n// =====================================\n\nconst PRODUCT_IDS = {\n  \"زيت سمسم سوداني فاخر|500ml\": 6171,\n  \"كركديه سوداني فاخر|250g\": 6172,\n\n  \"قهوة بوعسكور العربية السوداء|250g\": 3681,\n  \"قهوة بوعسكور العربية السوداء|500g\": 3681,\n  \"قهوة بوعسكور العربية السوداء|1kg\": 3681,\n\n  \"قهوة بوعسكور العربية البنية|250g\": 3682,\n  \"قهوة بوعسكور العربية البنية|500g\": 3682,\n  \"قهوة بوعسكور العربية البنية|1kg\": 3682,\n\n  \"قهوة بوعسكور العربية الشقراء|250g\": 5927,\n  \"قهوة بوعسكور العربية الشقراء|500g\": 5927,\n  \"قهوة بوعسكور العربية الشقراء|1kg\": 5927,\n\n  \"شاي تعليقة|عبوة\": 3680,\n  \"شاي تعليقة بلس|عبوة\": 3679,\n  \"شاي تلقيمة أصيل|عبوة\": 3678,\n  \"شاي تلقيمة سبيشل OP1|عبوة\": 3677,\n  \"شاي عراقي نخب أول|عبوة\": 3674\n};\n\n// =====================================\n// VARIATION IDS\n// =====================================\n\nconst VARIATION_IDS = {\n  \"قهوة بوعسكور العربية السوداء|250g\": 6275,\n  \"قهوة بوعسكور العربية السوداء|500g\": 6276,\n  \"قهوة بوعسكور العربية السوداء|1kg\": 6277,\n\n  \"قهوة بوعسكور العربية الشقراء|250g\": 6281,\n  \"قهوة بوعسكور العربية الشقراء|500g\": 6282,\n  \"قهوة بوعسكور العربية الشقراء|1kg\": 6283,\n\n  \"قهوة بوعسكور العربية البنية|250g\": 6286,\n  \"قهوة بوعسكور العربية البنية|500g\": 6287,\n  \"قهوة بوعسكور العربية البنية|1kg\": 6288,\n\n  \"زيت سمسم سوداني فاخر|500ml\": 6334\n};\n\n// =====================================\n// INPUTS\n// =====================================\n\nconst customer_name = $json.customer_name || '';\nconst phone = $json.phone || '';\nconst address = $json.address || '';\nconst area = $json.area || '';\nconst payment_method = $json.payment_method || 'الدفع عند الاستلام';\n\nlet cart = [];\n\ntry {\n  cart = JSON.parse($json.cart || '[]');\n} catch {\n  cart = [];\n}\n\n// =====================================\n// SHIPPING\n// =====================================\n\nconst specialAreas = [\n  'القوع',\n  'الوجن',\n  'الوقن',\n  'الظفرة',\n  'المنطقة الغربية',\n  'الرويس',\n  'غياثي',\n  'ليوا',\n  'المرفأ'\n];\n\nconst shippingCost =\n  specialAreas.some(a => address.includes(a) || area.includes(a))\n    ? 35\n    : 18;\n\n// =====================================\n// LINE ITEMS\n// =====================================\n\nconst line_items = [];\n\nfor (const item of cart) {\n\n  const key = `${item.product}|${item.weight}`;\n\n  const product_id = PRODUCT_IDS[key];\n\n  if (!product_id) {\n    continue;\n  }\n\n  const line = {\n    product_id,\n    quantity: Number(item.quantity || 1)\n  };\n\n  const variation_id = VARIATION_IDS[key];\n\n  if (variation_id) {\n    line.variation_id = variation_id;\n  }\n\n  line_items.push(line);\n}\n\n// =====================================\n// VALIDATION\n// =====================================\n\nif (!line_items.length) {\n  throw new Error('No valid products found');\n}\n\n// =====================================\n// WOO ORDER PAYLOAD\n// =====================================\n\nconst order_payload = {\n  payment_method: 'cod',\n  payment_method_title: 'الدفع عند الاستلام',\n  set_paid: false,\n  status: 'processing',\n\n  billing: {\n    first_name: customer_name,\n    phone: phone,\n    address_1: address,\n    country: 'AE'\n  },\n\n  shipping: {\n    first_name: customer_name,\n    address_1: address,\n    country: 'AE'\n  },\n\n  line_items,\n\n  shipping_lines: [\n    {\n      method_id: 'flat_rate',\n      method_title: 'توصيل',\n      total: String(shippingCost)\n    }\n  ],\n\n  customer_note: 'WhatsApp Order'\n};\n\n// =====================================\n// OUTPUT\n// =====================================\n\nreturn [{\n  json: {\n    ...$json,\n    shipping_cost: shippingCost,\n    order_payload\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        352
      ],
      "name": "Build WooCommerce Payload"
    },
